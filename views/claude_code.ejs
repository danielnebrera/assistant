<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Assistant</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.min.css">
  <script src="https://cdn.jsdelivr.net/npm/xterm@5.3.0/lib/xterm.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xterm-addon-fit@0.8.0/lib/xterm-addon-fit.min.js"></script>
  <style>
    *{box-sizing:border-box}
    html,body{margin:0;height:100%;background:#0b0f17;color:#d6e0f0;font-family:"Segoe UI",Arial,sans-serif}
    .app{display:flex;flex-direction:column;height:100vh}
    /* ── barra de marca + tabs ── */
    .topbar{display:flex;align-items:center;gap:18px;height:48px;padding:0 18px;background:#0e1422;border-bottom:1px solid #1d2740;flex-shrink:0}
    .brand{font-size:16px;font-weight:700;color:#fff;display:flex;align-items:center;gap:8px}
    .brand .b-emoji{font-size:18px}
    .tabs{display:flex;gap:4px}
    .tab{padding:8px 16px;border-radius:8px 8px 0 0;font-size:13.5px;cursor:pointer;color:#8ea3c4;border:1px solid transparent;border-bottom:none}
    .tab:hover{color:#c9d6ee;background:#16203a}
    .tab.active{color:#fff;background:#0b0f17;border-color:#1d2740}
    .panes{flex:1;min-height:0;position:relative}
    .pane{position:absolute;inset:0;display:none;overflow:auto}
    .pane.active{display:flex}
    /* ── genérico ── */
    .muted{color:#5b6b88}
    .btn{border:none;border-radius:7px;background:#2563eb;color:#fff;padding:9px 14px;font-size:13px;font-weight:600;cursor:pointer}
    .btn:hover{background:#1d4ed8}
    .btn.ghost{background:#1b2c4d}.btn.ghost:hover{background:#24386180}
    table{width:100%;border-collapse:collapse;font-size:13.5px}
    th,td{text-align:left;padding:10px 14px;border-bottom:1px solid #1a2440}
    th{color:#7da0d8;font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.04em}
    tbody tr{cursor:pointer} tbody tr:hover{background:#13203a}
    .badge{display:inline-block;padding:3px 10px;border-radius:999px;font-size:11.5px;font-weight:600;white-space:nowrap}
    .pill{display:inline-block;padding:2px 8px;border-radius:6px;font-size:11px;background:#1b2c4d;color:#9fc3ff}
    /* estados (colores semáforo del flujo) */
    .st-pendiente{background:#2a3550;color:#9fb2d8}
    .st-definicion{background:#1e3a5f;color:#7db1ff}
    .st-realizacion,.st-tests_auto,.st-ejecucion_tests{background:#3a2f5f;color:#c4a8ff}
    .st-aceptacion{background:#5a4410;color:#ffd580}
    .st-commit{background:#14432a;color:#5fd38a}
    .st-hecho{background:#14432a;color:#7ee2a8}
    /* ── Tareas: lista ── */
    .wrap{padding:20px 26px;width:100%}
    .head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .head h2{margin:0;font-size:18px;color:#fff}
    /* ── Tareas: detalle ── */
    .detail{display:flex;flex-direction:column;width:100%;height:100%}
    .dt-bar{display:flex;align-items:center;gap:14px;padding:12px 22px;background:#0e1422;border-bottom:1px solid #1d2740;flex-shrink:0}
    .dt-bar h2{margin:0;font-size:16px;color:#fff;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .stepper{display:flex;gap:6px;flex-wrap:wrap;padding:10px 22px;background:#0c1322;border-bottom:1px solid #16203a;flex-shrink:0}
    .step{font-size:11px;padding:3px 9px;border-radius:999px;background:#141d33;color:#5b6b88;white-space:nowrap}
    .step.done{background:#14321f;color:#5fd38a}
    .step.now{background:#1e3a5f;color:#fff;font-weight:700}
    .dt-body{flex:1;min-height:0;display:flex;flex-direction:column;overflow:auto;padding:18px 22px;gap:16px}
    .card{background:#0e1626;border:1px solid #1a2640;border-radius:10px;overflow:hidden}
    .card>.ch{padding:9px 14px;font-size:12px;font-weight:700;color:#7da0d8;text-transform:uppercase;letter-spacing:.04em;border-bottom:1px solid #1a2640;background:#0c1322}
    .card>.cb{padding:14px}
    /* Definición + Conversación en 2 columnas, cada una con scroll interno */
    .dt-top{display:flex;gap:16px;align-items:stretch;height:42vh;min-height:260px;max-height:540px;flex-shrink:0}
    .dt-top>.card{flex:1;min-width:0;display:flex;flex-direction:column;overflow:hidden}
    .dt-def>.cb{flex:1;min-height:0;overflow:auto;white-space:pre-wrap}
    .dt-conv>.chat{flex:1;min-height:0;max-height:none}
    /* definición */
    #defText{font-size:14px;line-height:1.6;color:#d6e0f0;white-space:pre-wrap}
    /* chat */
    .chat{display:flex;flex-direction:column;gap:10px;max-height:340px;overflow:auto;padding:14px}
    .bub{max-width:78%;padding:9px 13px;border-radius:12px;font-size:13.5px;line-height:1.5;white-space:pre-wrap}
    .bub.user{align-self:flex-end;background:#1d4ed8;color:#fff;border-bottom-right-radius:3px}
    .bub.assistant{align-self:flex-start;background:#16203a;color:#d6e0f0;border-bottom-left-radius:3px}
    .chat-in{display:flex;gap:8px;padding:12px 14px;border-top:1px solid #1a2640;background:#0c1322}
    .chat-in textarea{flex:1;resize:none;background:#0b1120;border:1px solid #243861;border-radius:8px;color:#e6eefc;padding:10px 12px;font-size:13.5px;font-family:inherit;min-height:42px;max-height:120px}
    /* columnas de agentes */
    .agents{display:flex;gap:12px;overflow-x:auto;padding-bottom:6px}
    .agent{flex:0 0 320px;display:flex;flex-direction:column;background:#0b1120;border:1px solid #1a2640;border-radius:10px;overflow:hidden;min-height:240px}
    .agent .ah{padding:9px 12px;font-size:12.5px;font-weight:700;border-bottom:1px solid #1a2640;display:flex;align-items:center;gap:8px;background:#0c1424}
    .agent.strat .ah{color:#ffd580}
    .agent .ah .tag{font-size:10px;font-weight:600;padding:2px 7px;border-radius:6px;background:#1b2c4d;color:#9fc3ff}
    .agent .alog{flex:1;padding:10px 12px;font-family:Consolas,Menlo,monospace;font-size:12px;color:#9fb2d8;white-space:pre-wrap;overflow:auto;min-height:0}
    .dot-s{width:8px;height:8px;border-radius:50%;background:#30363d;flex-shrink:0}
    .dot-s.running{background:#3fb950}.dot-s.exited{background:#f85149}
    /* log del Estratega (texto legible, no monospace) + notas */
    .agent.strat .alog{font-family:inherit;font-size:12.5px;line-height:1.45}
    .strat-note{padding:6px 2px;border-bottom:1px solid #14203a;color:#d6e0f0;white-space:pre-wrap}
    .strat-note:last-child{border-bottom:none}
    /* indicador "Trabajando…" en el chat (traducción de negocio de la actividad) */
    .bub.work-ind{background:#16203a;color:#9fb2d8;font-style:italic;opacity:.85}
    .btn:disabled{opacity:.4;cursor:default}
    /* ── Terminal ── */
    .term-layout{display:flex;height:100%;width:100%}
    .side{width:220px;background:#0e1422;border-right:1px solid #1d2740;display:flex;flex-direction:column;flex-shrink:0}
    .side .acts{padding:10px}
    .side .acts button{width:100%}
    .sess{flex:1;overflow-y:auto;padding:4px 10px}
    .sess .it{padding:9px 10px;border-radius:7px;font-size:13px;cursor:pointer;color:#aebbd4;display:flex;justify-content:space-between;gap:6px;align-items:center}
    .sess .it:hover{background:#16203a}.sess .it.active{background:#1b2c4d;color:#fff}
    .sess .it .x{color:#ff8a8a;opacity:.6}.sess .it .x:hover{opacity:1}
    .sess .it .sname{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .rename-in{width:100%;background:#0b1120;border:1px solid #2563eb;border-radius:5px;color:#fff;font:inherit;font-size:13px;padding:2px 6px}
    .rename-in:focus{outline:none}
    .term-main{flex:1;display:flex;flex-direction:column;min-width:0}
    .term-bar{height:38px;display:flex;align-items:center;gap:10px;padding:0 14px;background:#0e1422;border-bottom:1px solid #1d2740;font-size:13px;color:#8ea3c4}
    .dot{width:8px;height:8px;border-radius:50%;background:#4ade80}.dot.off{background:#f87171}
    #term{flex:1;padding:6px 8px;min-height:0}
    .empty{flex:1;display:flex;align-items:center;justify-content:center;color:#5b6b88;font-size:14px;text-align:center;padding:20px}
    .hint{font-size:12px;color:#5b6b88;margin-top:6px}
    /* ── barra táctil (solo móvil): scroll del historial + flechas para elegir ── */
    .touchbar{display:none}
    /* ── cuadro "Copiar texto" (selección/copiado nativos del navegador) ── */
    .copy-ov{position:fixed;inset:0;background:rgba(2,6,16,.78);display:none;align-items:center;justify-content:center;z-index:9999}
    .copy-ov.on{display:flex}
    .copy-box{width:min(900px,92vw);height:min(80vh,700px);background:#0e1626;border:1px solid #243861;border-radius:12px;display:flex;flex-direction:column;overflow:hidden}
    .copy-box .cbh{display:flex;align-items:center;gap:10px;padding:10px 14px;border-bottom:1px solid #1a2640;color:#cfe0ff;font-size:13px}
    .copy-box textarea{flex:1;width:100%;border:none;resize:none;background:#0b1120;color:#d6e0f0;font-family:Consolas,Menlo,monospace;font-size:12.5px;line-height:1.5;padding:12px 14px}
    .copy-box textarea:focus{outline:none}
    /* ── Móvil vertical: terminal a todo el ancho ── */
    @media (max-width:700px){
      .topbar{gap:10px;padding:0 12px}
      .brand{font-size:14px}
      .tabs{flex:1;overflow-x:auto}
      .tab{padding:8px 11px;font-size:13px;white-space:nowrap}
      .wrap{padding:14px}
      .dt-bar,.stepper,.dt-body{padding-left:14px;padding-right:14px}
      /* las 2 columnas (definición/conversación) se apilan en móvil */
      .dt-top{flex-direction:column;height:auto;max-height:none}
      .dt-def>.cb{max-height:240px}
      .dt-conv>.chat{max-height:340px}
      .bub{max-width:90%}
      /* la barra lateral de sesiones pasa a ser una tira horizontal arriba */
      .term-layout{flex-direction:column}
      .side{width:100%;flex-direction:row;align-items:center;border-right:none;border-bottom:1px solid #1d2740}
      .side .acts{padding:8px;flex-shrink:0}
      .side .acts button{width:auto;white-space:nowrap;padding:8px 12px}
      .sess{flex:1;display:flex;flex-direction:row;align-items:center;gap:6px;overflow-x:auto;overflow-y:hidden;padding:6px 8px}
      .sess .it{flex:0 0 auto;max-width:170px}
      /* el terminal ocupa todo el ancho restante y conserva su scrollback táctil */
      .term-main{min-width:0;width:100%}
      .term-bar{height:auto;flex-wrap:wrap;padding:6px 10px;gap:6px}
      #copyHint{display:none}
      #term{padding:4px 4px 0;touch-action:pan-y}
      .xterm .xterm-viewport{touch-action:pan-y;-webkit-overflow-scrolling:touch}
      /* barra táctil al pie del terminal */
      .touchbar{display:flex;flex-wrap:wrap;align-items:center;gap:6px;padding:7px 8px;background:#0e1422;border-top:1px solid #1d2740;flex-shrink:0}
      .tb-lbl{font-size:10px;color:#5b6b88;text-transform:uppercase;letter-spacing:.04em;margin:0 1px 0 4px}
      .tb-btn{min-width:44px;height:40px;border:1px solid #243861;border-radius:8px;background:#16203a;color:#cfe0ff;font-size:17px;font-weight:600;display:inline-flex;align-items:center;justify-content:center;gap:4px;padding:0 10px;cursor:pointer;-webkit-tap-highlight-color:transparent;user-select:none}
      .tb-btn:active{background:#243861}
      .tb-btn small{font-size:10px;font-weight:600}
      .tb-btn.tb-ok{background:#14803a;border-color:#1d9b4a;color:#fff}
      .tb-sep{width:1px;align-self:stretch;background:#1d2740;margin:2px}
    }
  </style>
</head>
<body>
<div class="app">
  <div class="topbar">
    <div class="brand"><span class="b-emoji">🤖</span> Assistant</div>
    <div class="tabs">
      <div class="tab active" data-tab="tareas">Tareas</div>
      <div class="tab" data-tab="modulos">Módulos</div>
      <div class="tab" data-tab="terminal">Terminal</div>
    </div>
  </div>

  <div class="panes">
    <!-- ════════════ TAREAS ════════════ -->
    <section class="pane active" id="pane-tareas" style="flex-direction:column">
      <!-- lista -->
      <div class="wrap" id="taskList">
        <div class="head">
          <h2>Tareas</h2>
          <button class="btn" id="btnNewTask">+ Nueva tarea</button>
        </div>
        <table>
          <thead><tr><th>Tarea</th><th>Estado</th><th>Cambios guardados</th><th>Actualizada</th></tr></thead>
          <tbody id="taskRows"><tr><td colspan="4" class="muted">Cargando…</td></tr></tbody>
        </table>
        <div class="hint">Cada tarea es una sesión de trabajo. Cuéntale al asistente qué quieres en lenguaje normal; él se encarga de lo técnico.</div>
      </div>
      <!-- detalle -->
      <div class="detail" id="taskDetail" style="display:none">
        <div class="dt-bar">
          <button class="btn ghost" id="btnBack">← Volver</button>
          <h2 id="dtTitle"></h2>
          <span class="badge" id="dtBadge"></span>
        </div>
        <div class="stepper" id="dtStepper"></div>
        <div class="dt-body">
          <div class="dt-top">
            <div class="card dt-def">
              <div class="ch">Definición de la tarea</div>
              <div class="cb"><div id="defText" class="muted">Aún sin definir. Escribe abajo lo que necesitas y el asistente resumirá aquí el objetivo de la tarea.</div></div>
            </div>
            <div class="card dt-conv">
              <div class="ch">Conversación</div>
              <div class="chat" id="dtChat"></div>
              <div class="chat-in">
                <textarea id="dtInput" placeholder="Escribe aquí lo que quieres conseguir…" rows="1"></textarea>
                <button class="btn" id="dtSend">Enviar</button>
              </div>
            </div>
          </div>
          <div class="card">
            <div class="ch" style="display:flex;align-items:center;gap:10px">Trabajo de los agentes
              <span style="flex:1"></span>
              <span id="supInd" title="El Estratega revisa y coordina a los agentes automáticamente" style="display:none;font-size:12px;font-weight:600;color:#9fc3ff;text-transform:none;letter-spacing:0">🤖 Supervisión automática</span>
            </div>
            <div class="cb"><div class="agents" id="dtAgents"></div></div>
          </div>
          <div class="card" id="dtCommitsCard" style="display:none">
            <div class="ch">Cambios guardados</div>
            <div class="cb"><div id="dtCommits"></div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════════════ MÓDULOS ════════════ -->
    <section class="pane" id="pane-modulos" style="flex-direction:column">
      <div class="wrap">
        <div class="head"><h2>Módulos de la aplicación</h2></div>
        <table>
          <thead><tr><th>Módulo</th><th>Contrato (SPEC)</th><th>Ruta</th><th>Estado</th></tr></thead>
          <tbody id="modRows"><tr><td colspan="4" class="muted">Cargando…</td></tr></tbody>
        </table>
        <div class="hint">Cada módulo (o «sección») es una parte independiente de la app. El asistente abre un agente por módulo cuando una tarea lo necesita.</div>
      </div>
    </section>

    <!-- ════════════ TERMINAL ════════════ -->
    <section class="pane" id="pane-terminal">
      <div class="term-layout">
        <aside class="side">
          <div class="acts"><button class="btn" onclick="Term.newSession()">+ Nueva sesión</button></div>
          <div class="sess" id="sessList"></div>
        </aside>
        <div class="term-main">
          <div class="term-bar"><span class="dot off" id="dot"></span><span id="status">Sin conectar</span><button class="btn ghost" style="padding:4px 10px;font-size:12px" onclick="Term.openCopyText()">📋 Copiar texto</button><button class="btn ghost" style="padding:4px 10px;font-size:12px" onclick="Term.openPaste()">📥 Pegar</button><span style="flex:1"></span><span id="copyHint" style="font-size:11.5px;color:#7da0d8;opacity:.5;transition:opacity .2s">📋 Copiar texto, o Shift+arrastrar + botón derecho</span><span id="termTitle"></span></div>
          <div id="term"></div>
          <div class="empty" id="empty">Crea o selecciona una sesión para empezar.</div>
          <!-- Barra táctil (solo móvil): desplazar el historial y mover la selección de opciones -->
          <div class="touchbar" id="touchbar">
            <span class="tb-lbl">Texto</span>
            <button class="tb-btn" data-act="pageup"   title="Ver texto de más arriba">⬆</button>
            <button class="tb-btn" data-act="pagedown" title="Ver texto de más abajo">⬇</button>
            <button class="tb-btn" data-act="bottom"   title="Ir al final (texto en vivo)">⤓<small>final</small></button>
            <span class="tb-sep"></span>
            <button class="tb-btn" data-act="paste" title="Pegar texto del portapapeles">📥<small>pegar</small></button>
            <span class="tb-sep"></span>
            <span class="tb-lbl">Opción</span>
            <button class="tb-btn" data-act="up"    title="Subir la selección">↑</button>
            <button class="tb-btn" data-act="down"  title="Bajar la selección">↓</button>
            <button class="tb-btn tb-ok" data-act="enter" title="Elegir / confirmar">✓<small>elegir</small></button>
            <button class="tb-btn" data-act="tab"   title="Tab — aceptar la opción por defecto">⇥<small>tab</small></button>
            <button class="tb-btn" data-act="esc"   title="Escape / cancelar">esc</button>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

<!-- Cuadro para copiar texto del terminal con selección/copiado NATIVOS del navegador -->
<div class="copy-ov" id="copyOv">
  <div class="copy-box">
    <div class="cbh">
      <b>Copiar texto del terminal</b>
      <span style="color:#7da0d8;font-size:12px">Selecciona con el ratón y copia (botón derecho → Copiar, o Ctrl+C). Todo el texto ya viene seleccionado.</span>
      <span style="flex:1"></span>
      <button class="btn" style="padding:5px 12px;font-size:12px" onclick="Term.copyAllText()">Copiar todo</button>
      <button class="btn ghost" style="padding:5px 12px;font-size:12px" onclick="Term.closeCopyText()">Cerrar ✕</button>
    </div>
    <textarea id="copyArea" spellcheck="false" readonly></textarea>
  </div>
</div>

<!-- Cuadro para PEGAR texto en el terminal (pega aquí con el método nativo del dispositivo) -->
<div class="copy-ov" id="pasteOv">
  <div class="copy-box" style="height:min(60vh,460px)">
    <div class="cbh">
      <b>Pegar texto en el terminal</b>
      <span style="color:#7da0d8;font-size:12px">Pega aquí (Ctrl+V en Windows, o mantén pulsado → Pegar en Android) y dale a «Enviar».</span>
      <span style="flex:1"></span>
      <button class="btn" style="padding:5px 12px;font-size:12px" onclick="Term.pasteSend()">Enviar al terminal ⏎</button>
      <button class="btn ghost" style="padding:5px 12px;font-size:12px" onclick="Term.closePaste()">Cerrar ✕</button>
    </div>
    <textarea id="pasteArea" spellcheck="false" placeholder="Pega aquí el texto…"></textarea>
  </div>
</div>

<script>
const esc = s => String(s == null ? '' : s).replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const $ = id => document.getElementById(id);

/* ════════════ Pestañas ════════════ */
const Tabs = {
  show(name){
    document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name));
    document.querySelectorAll('.pane').forEach(p => p.classList.toggle('active', p.id === 'pane-' + name));
    if (name === 'tareas')  Tasks.loadList();
    if (name === 'modulos') Modules.load();
    if (name === 'terminal') Term.activate();
  }
};
document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => Tabs.show(t.dataset.tab)));

/* ════════════ Módulos ════════════ */
const Modules = {
  async load(){
    try {
      const r = await fetch('/assistant/api/modules'); const { modules } = await r.json();
      $('modRows').innerHTML = (modules || []).map(m => `
        <tr style="cursor:default">
          <td><b style="color:#fff">${esc(m.label || m.name)}</b></td>
          <td>${m.has_spec ? '<span class="pill">SPEC.md</span>' : '<span class="muted">— sin contrato —</span>'}</td>
          <td class="muted" style="font-family:monospace;font-size:12px">${esc(m.path)}</td>
          <td>${m.active ? '<span class="badge st-hecho">activo</span>' : '<span class="badge st-pendiente">retirado</span>'}</td>
        </tr>`).join('') || '<tr><td colspan="4" class="muted">Sin módulos.</td></tr>';
    } catch(e){ $('modRows').innerHTML = '<tr><td colspan="4" class="muted">Error al cargar.</td></tr>'; }
  }
};

/* ════════════ Tareas ════════════ */
const Tasks = {
  statuses: [], statusByKey: {}, current: null,
  fmt(ts){ try { return new Date(ts).toLocaleString('es-ES', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'}); } catch(e){ return ''; } },
  label(k){ return (this.statusByKey[k] && this.statusByKey[k].label) || k; },

  async loadList(){
    Tasks.showList();
    try {
      const r = await fetch('/assistant/api/tasks'); const d = await r.json();
      Tasks.statuses = d.statuses || []; Tasks.statusByKey = Object.fromEntries(Tasks.statuses.map(s => [s.key, s]));
      const rows = (d.tasks || []).map(t => `
        <tr onclick="Tasks.open(${t.id})">
          <td><b style="color:#fff">${esc(t.title)}</b></td>
          <td><span class="badge st-${t.status}">${esc(Tasks.label(t.status))}</span></td>
          <td>${t.commit_count > 0 ? '<span class="pill">'+t.commit_count+'</span>' : '<span class="muted">—</span>'}</td>
          <td class="muted">${Tasks.fmt(t.updated_at)}</td>
        </tr>`).join('');
      $('taskRows').innerHTML = rows || '<tr><td colspan="4" class="muted">No hay tareas todavía. Crea la primera.</td></tr>';
    } catch(e){ $('taskRows').innerHTML = '<tr><td colspan="4" class="muted">Error al cargar.</td></tr>'; }
  },

  showList(){ Sup.stop(); AgentLogs.reset(); Tasks.current = null; $('taskList').style.display = ''; $('taskDetail').style.display = 'none'; },
  showDetail(){ $('taskList').style.display = 'none'; $('taskDetail').style.display = 'flex'; },

  async create(){
    const title = prompt('¿Qué quieres hacer? (un título breve para la tarea)');
    if (!title || !title.trim()) return;
    const r = await fetch('/assistant/api/tasks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ title: title.trim() }) });
    const d = await r.json();
    if (d.id) Tasks.open(d.id); else alert(d.error || 'No se pudo crear');
  },

  async open(id){
    if (Tasks.current !== id){ AgentLogs.reset(); $('dtAgents').dataset.sig = ''; }
    Tasks.current = id; Tasks.showDetail();
    const r = await fetch('/assistant/api/tasks/' + id);
    if (!r.ok) { alert('No se pudo abrir la tarea'); Tasks.showList(); return; }
    const d = await r.json();
    Tasks.render(d);
  },

  render(d){
    if (d.statuses){ Tasks.statuses = d.statuses; Tasks.statusByKey = Object.fromEntries(d.statuses.map(s => [s.key, s])); }
    const t = d.task;
    $('dtTitle').textContent = t.title;
    $('dtBadge').className = 'badge st-' + t.status;
    $('dtBadge').textContent = Tasks.label(t.status);
    // stepper
    const cur = Tasks.statusByKey[t.status] ? Tasks.statusByKey[t.status].step : 0;
    $('dtStepper').innerHTML = Tasks.statuses.filter(s => s.key !== 'pendiente').map(s =>
      `<span class="step ${s.step < cur ? 'done' : (s.step === cur ? 'now' : '')}">${esc(s.label)}</span>`).join('');
    // definición
    if (t.definition && t.definition.trim()){ $('defText').textContent = t.definition; $('defText').className = ''; }
    else { $('defText').textContent = 'Aún sin definir. Escribe abajo lo que necesitas y el asistente resumirá aquí el objetivo de la tarea.'; $('defText').className = 'muted'; }
    // El usuario solo habla por el chat: lanzar, probar y guardar se ordenan por chat.
    // Supervisión automática del Estratega: activa mientras haya algún agente vivo.
    const anyRunning = (d.agents || []).some(a => a.kind === 'modulo' && a.status === 'running');
    $('supInd').style.display = anyRunning ? '' : 'none';
    Tasks._anyRunning = anyRunning;
    Sup.sync(anyRunning);
    // chat (solo negocio) + indicador "Trabajando…" mientras haya agentes activos
    Tasks.renderChat(d.messages || [], anyRunning);
    // agentes (columnas) + log técnico del Estratega en su columna
    Tasks.renderAgents(d.agents || []);
    Tasks.renderEstrategaLog(d.messages || []);
    // commits ligados a la tarea
    Tasks.renderCommits(d.commits || []);
  },

  renderCommits(commits){
    const card = $('dtCommitsCard');
    if (!commits.length){ card.style.display = 'none'; return; }
    card.style.display = '';
    $('dtCommits').innerHTML = commits.map(c => `
      <div style="display:flex;gap:10px;align-items:center;padding:6px 0;border-bottom:1px solid #14203a">
        <span class="pill" style="font-family:monospace">${esc((c.sha||'').slice(0,8))}</span>
        <span style="flex:1">${esc(c.message || '')}</span>
        <span class="muted" style="font-size:12px">${Tasks.fmt(c.created_at)}</span>
      </div>`).join('');
  },

  renderChat(msgs, working){
    const box = $('dtChat');
    // El chat es SOLO diálogo de negocio usuario↔Estratega. Las notas técnicas de
    // coordinación (rol 'estratega') NO van aquí, sino a la columna del Estratega.
    const chat = (msgs || []).filter(m => m.role === 'user' || m.role === 'assistant');
    let html = chat.length
      ? chat.map(m => `<div class="bub ${m.role === 'user' ? 'user' : 'assistant'}">${esc(m.content)}</div>`).join('')
      : '<div class="muted" style="text-align:center;padding:20px 0">Empieza la conversación contando qué necesitas.</div>';
    // Traducción de negocio de la actividad técnica: mientras trabaja, "Trabajando…".
    if (working) html += '<div class="bub assistant work-ind">⚙️ Trabajando…</div>';
    box.innerHTML = html;
    box.scrollTop = box.scrollHeight;
  },

  // Log TÉCNICO del Estratega (rol 'estratega'): supervisión + acciones. Va en su
  // columna de la parrilla, no en el chat. Se refresca en cada render (no depende
  // de que cambien los agentes de módulo).
  renderEstrategaLog(msgs){
    const el = $('stratLog'); if (!el) return;
    const notes = (msgs || []).filter(m => m.role === 'estratega');
    if (!notes.length){
      el.innerHTML = '<span class="muted">El Estratega traduce lo que pides, reparte el trabajo a los módulos y los supervisa. Aquí verás lo que va haciendo.</span>';
      return;
    }
    el.innerHTML = notes.map(m => `<div class="strat-note">${esc(m.content)}</div>`).join('');
    el.scrollTop = el.scrollHeight;
  },

  renderAgents(agents){
    const box = $('dtAgents');
    const mods = agents.filter(a => a.kind === 'modulo');
    // firma para no reconstruir (y re-enganchar el WS) en cada render si no cambió
    const sig = Tasks.current + '|' + mods.map(a => a.id + ':' + a.status + ':' + (a.tmux_name || '') + ':' + (a.test_status || '')).join(',');
    if (box.dataset.sig === sig) return;
    box.dataset.sig = sig;
    AgentLogs.reset();
    // Columna del Estratega (siempre) + una por módulo (log en vivo).
    let html = `<div class="agent strat">
      <div class="ah"><span class="dot-s ${mods.some(a => a.status === 'running') ? 'running' : ''}"></span>Estratega
        <span style="flex:1"></span><span class="tag">Estratega</span></div>
      <div class="alog strat-log" id="stratLog"><span class="muted">El Estratega reparte el trabajo a los módulos y los supervisa. Aquí verás lo que va haciendo.</span></div>
    </div>`;
    const tb = { passed:'✅ tests', failed:'❌ tests', running:'⏳ tests', none:'' };
    html += mods.map(a => `<div class="agent" data-agent="${a.id}">
      <div class="ah"><span class="dot-s ${a.status || ''}" id="agdot-${a.id}"></span>${esc(a.title || a.module_name)}
        <span class="tag">${esc(a.module_name || '')}</span><span style="flex:1"></span>
        ${a.test_status && a.test_status !== 'none' ? '<span class="tag" style="background:'+(a.test_status==='passed'?'#14432a':a.test_status==='failed'?'#5a1a1a':'#3a2f5f')+'">'+tb[a.test_status]+'</span>' : ''}
        <span class="tag">Módulo</span></div>
      <div class="alog" id="agterm-${a.id}" style="padding:2px"></div>
    </div>`).join('');
    box.innerHTML = html;
    AgentLogs.build(mods);
  },

  async send(){
    const ta = $('dtInput'); const content = ta.value.trim();
    if (!content || Tasks.sending || !Tasks.current) return;
    const id = Tasks.current;
    Tasks.sending = true; $('dtSend').disabled = true;
    ta.value = ''; ta.style.height = 'auto';
    // pinta el mensaje del usuario + "pensando…" de inmediato
    const box = $('dtChat');
    if (box.querySelector('.muted')) box.innerHTML = '';
    box.insertAdjacentHTML('beforeend', `<div class="bub user">${esc(content)}</div>`);
    box.insertAdjacentHTML('beforeend', `<div class="bub assistant" id="thinking"><span class="muted">El asistente está pensando…</span></div>`);
    box.scrollTop = box.scrollHeight;
    try {
      const r = await fetch('/assistant/api/tasks/' + id + '/messages', {
        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ content }) });
      const d = await r.json();
      if (!r.ok) { const th = $('thinking'); if (th) th.innerHTML = '<span class="muted">' + esc(d.error || 'No se pudo enviar') + '</span>'; return; }
      if (id === Tasks.current) Tasks.render(d);
    } catch(e){
      const th = $('thinking'); if (th) th.innerHTML = '<span class="muted">Error de conexión. Inténtalo de nuevo.</span>';
    } finally {
      Tasks.sending = false; $('dtSend').disabled = false;
    }
  }
};
/* ════════════ Logs en vivo de los agentes (un xterm por columna) ════════════ */
const AgentLogs = {
  ws:null, cols:new Map(), byTmux:new Map(), _retry:null, _hb:null, _lastRx:0,
  reset(){
    if (this._retry){ clearTimeout(this._retry); this._retry = null; }
    this._stopHB();
    this.cols.forEach(c => { try { c.term.dispose(); } catch(e){} });
    this.cols.clear(); this.byTmux.clear();
    if (this.ws){ try { this.ws.onclose = null; this.ws.close(); } catch(e){} this.ws = null; }
  },
  build(mods){
    mods.forEach(a => {
      const el = document.getElementById('agterm-' + a.id);
      if (!el || !a.tmux_name) return;
      const term = new Terminal({ cursorBlink:false, fontSize:11, fontFamily:'Consolas,Menlo,monospace',
        scrollback:3000, theme:{ background:'#0b1120', foreground:'#9fb2d8' } });
      const fit = new FitAddon.FitAddon(); term.loadAddon(fit);
      term.open(el); try { fit.fit(); } catch(e){}
      // Solo lectura: el usuario NO escribe a los agentes (solo habla con el chat;
      // el Estratega los gestiona). No reenviamos las teclas al pane del agente.
      const col = { term, fit, tmux:a.tmux_name, agentId:a.id };
      this.cols.set(a.id, col); this.byTmux.set(a.tmux_name, col);
    });
    if (this.cols.size) this.connect();
  },
  connect(){
    if (this._retry){ clearTimeout(this._retry); this._retry = null; }
    const proto = location.protocol === 'https:' ? 'wss' : 'ws';
    this.ws = new WebSocket(proto + '://' + location.host + '/ws/assistant');
    // onopen re-engancha TODAS las columnas (agent_attach): vale tanto para la
    // primera conexión como para una reconexión — los tmux ag_<id> siguen vivos.
    this.ws.onopen = () => { this._lastRx = Date.now(); this._startHB(); this.cols.forEach((c, id) => this.send({ type:'agent_attach', agentId:id, cols:c.term.cols, rows:c.term.rows })); };
    this.ws.onmessage = ev => { this._lastRx = Date.now(); let m; try { m = JSON.parse(ev.data); } catch(e){ return; } if (m.type==='pong') return; this.handle(m); };
    // Reconexión transparente igual que el terminal: si la caída no fue deliberada
    // (reset() anula este onclose) y aún hay columnas que mostrar, reintenta.
    this.ws.onclose = () => { this._stopHB(); if (this.cols.size){ this._retry = setTimeout(() => this.connect(), 1500); } };
    this.ws.onerror = () => {};
  },
  // Watchdog igual que Term: sonda cada 15s, fuerza cierre tras 40s sin recibir.
  _startHB(){ this._stopHB(); this._hb = setInterval(() => this._tick(), 15000); },
  _stopHB(){ if (this._hb){ clearInterval(this._hb); this._hb = null; } },
  _tick(){
    if (!this.ws || this.ws.readyState !== 1) return;
    if (Date.now() - this._lastRx > 40000){ try { this.ws.close(); } catch(e){} return; }
    this.send({ type:'ping' });
  },
  wake(){
    if (!this.cols.size) return;
    const rs = this.ws ? this.ws.readyState : 3;
    if (rs === 1) this.send({ type:'ping' });
    else if (rs !== 0) this.connect();
  },
  send(o){ if (this.ws && this.ws.readyState === 1) this.ws.send(JSON.stringify(o)); },
  handle(m){
    if (m.type === 'output'){ const c = this.byTmux.get(m.sessionId); if (c) c.term.write(m.data); }
    else if (m.type === 'exit' || m.type === 'detached'){
      const c = this.byTmux.get(m.sessionId); if (c){ const dot = document.getElementById('agdot-' + c.agentId); if (dot) dot.className = 'dot-s exited'; }
    }
  }
};

$('btnNewTask').addEventListener('click', () => Tasks.create());
$('btnBack').addEventListener('click', () => Tasks.showList());
/* ══════ Supervisión AUTOMÁTICA del Estratega (tick mientras haya agentes vivos) ══ */
const Sup = {
  timer:null, busy:false, INTERVAL:30000,
  // arranca/para el tick según haya agentes vivos (siempre automático, sin control de usuario)
  sync(anyRunning){ if (anyRunning) Sup.start(); else Sup.stop(); },
  start(){ if (Sup.timer) return; Sup.timer = setInterval(() => Sup.tick(), Sup.INTERVAL); setTimeout(() => Sup.tick(), 1500); },
  stop(){ if (Sup.timer){ clearInterval(Sup.timer); Sup.timer = null; } },
  async tick(){
    if (Sup.busy || !Tasks.current) return;
    Sup.busy = true;
    try {
      const r = await fetch('/assistant/api/tasks/' + Tasks.current + '/supervise', { method:'POST' });
      if (r.ok){ const d = await r.json(); if (Tasks.current && d && d.task) Tasks.render(d); }
    } catch(e){} finally { Sup.busy = false; }
  }
};
$('dtSend').addEventListener('click', () => Tasks.send());
$('dtInput').addEventListener('input', e => { e.target.style.height = 'auto'; e.target.style.height = Math.min(e.target.scrollHeight, 120) + 'px'; });
$('dtInput').addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey){ e.preventDefault(); Tasks.send(); } });
$('copyOv').addEventListener('click', e => { if (e.target.id === 'copyOv') Term.closeCopyText(); });
$('pasteOv').addEventListener('click', e => { if (e.target.id === 'pasteOv') Term.closePaste(); });
// Ctrl/Cmd+Enter en el cuadro de pegado = enviar al terminal.
$('pasteArea').addEventListener('keydown', e => { if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)){ e.preventDefault(); Term.pasteSend(); } });
document.addEventListener('keydown', e => {
  if (e.key !== 'Escape') return;
  if ($('copyOv').classList.contains('on')) Term.closeCopyText();
  else if ($('pasteOv').classList.contains('on')) Term.closePaste();
});

/* Reconexión inmediata al recuperar red o volver a la pestaña: no esperamos a que el
   navegador descubra por su cuenta un socket medio-abierto (la causa de tener que
   refrescar tras suspender el equipo o cambiar de wifi). */
window.addEventListener('online', () => { Term.wake(); AgentLogs.wake(); });
document.addEventListener('visibilitychange', () => { if (!document.hidden){ Term.wake(); AgentLogs.wake(); } });

/* ════════════ Terminal (motor tmux existente) ════════════ */
const Term = {
  ws:null, term:null, fit:null, current:null, sessions:[], inited:false, started:false, _hb:null, _lastRx:0, _retry:null,
  setStatus(txt, on){ $('status').textContent = txt; $('dot').className = 'dot' + (on?'':' off'); },
  activate(){ if (!Term.inited){ Term.init(); Term.connect(); Term.inited = true; } else { Term.doFit(); } },
  init(){
    Term.term = new Terminal({ cursorBlink:true, fontSize:13, fontFamily:'Consolas,Menlo,monospace',
      scrollback:5000, theme:{ background:'#0b0f17', foreground:'#d6e0f0' } });
    Term.fit = new FitAddon.FitAddon(); Term.term.loadAddon(Term.fit);
    Term.term.open($('term')); Term.doFit();
    Term.term.onData(d => { if (Term.current) Term.send({ type:'input', sessionId:Term.current, data:d }); });
    window.addEventListener('resize', () => { if ($('pane-terminal').classList.contains('active')) Term.doFit(); });

    // ── Copiar/pegar (Windows) ──────────────────────────────────────────────
    // claude/tmux activan el "modo ratón": para seleccionar con el ratón mantén
    // SHIFT y arrastra (xterm fuerza la selección local). Para copiar la selección:
    // botón derecho, o Ctrl+C (cuando hay algo seleccionado), o Ctrl+Shift+C.
    // Pegar: botón "📥 Pegar" (Windows y Android), o Ctrl+Shift+V. En móvil hay además
    // un botón "pegar" en la barra táctil. Si el navegador bloquea el portapapeles, se
    // abre un cuadro donde se pega con el método nativo del dispositivo y se envía.
    Term.copyText = (text) => {
      if (!text) return Promise.resolve(false);
      if (navigator.clipboard && navigator.clipboard.writeText)
        return navigator.clipboard.writeText(text).then(() => true).catch(() => Term._execCopy(text));
      return Promise.resolve(Term._execCopy(text));
    };
    Term._execCopy = (text) => {            // fallback sin Clipboard API (más tolerante)
      try {
        const ta = document.createElement('textarea');
        ta.value = text; ta.style.position = 'fixed'; ta.style.top = '0'; ta.style.opacity = '0';
        document.body.appendChild(ta); ta.focus(); ta.select();
        const ok = document.execCommand('copy'); document.body.removeChild(ta);
        return ok;
      } catch (e) { return false; }
    };
    // Guardamos la ÚLTIMA selección no vacía: el clic derecho a veces borra la
    // selección antes de que la leamos, así que copiamos la guardada.
    Term._lastSel = '';
    Term.term.onSelectionChange(() => {
      const s = Term.term.getSelection();
      if (s && s.length){ Term._lastSel = s; const el = $('copyHint'); if (el){ el.textContent = s.length + ' seleccionado — botón derecho o Ctrl+C copia'; el.style.opacity = '1'; } }
    });
    Term.copy = () => {
      let sel = Term.term.getSelection(); if (!sel || !sel.length) sel = Term._lastSel;
      if (!sel || !sel.length){ Term.flash('Nada seleccionado (mantén Shift y arrastra)'); return false; }
      Term.copyText(sel).then(ok => Term.flash(ok ? 'Copiado ✓ (' + sel.length + ')' : 'No se pudo copiar'));
      return true;
    };
    // Vuelca el texto al terminal por la MISMA vía que teclear (term.paste): así se
    // respeta el "bracketed paste" cuando claude/el shell lo activan y un pegado de
    // varias líneas NO se ejecuta línea a línea.
    Term.doPaste = (text) => { if (text && Term.current && Term.term){ Term.term.paste(text); return true; } return false; };
    // Ctrl+Shift+V: misma lógica que el botón "Pegar".
    Term.paste = () => Term.openPaste();
    // Botón derecho = copiar (selección actual o la última guardada).
    $('term').addEventListener('contextmenu', (e) => { e.preventDefault(); Term.copy(); });
    Term.term.attachCustomKeyEventHandler((e) => {
      if (e.type !== 'keydown' || !e.ctrlKey) return true;
      const k = e.key.toLowerCase();
      // Ctrl+C: si hay selección copia (y NO manda interrumpir); si no, pasa (SIGINT).
      if (k === 'c' && !e.shiftKey){ if (Term.term.getSelection() || Term._lastSel){ Term.copy(); e.preventDefault(); return false; } return true; }
      if (!e.shiftKey) return true;
      if (k === 'c'){ Term.copy(); e.preventDefault(); return false; }   // Ctrl+Shift+C
      if (k === 'v'){ Term.paste(); e.preventDefault(); return false; }  // Ctrl+Shift+V
      return true;
    });
  },
  flash(txt){ const el = $('copyHint'); if(!el) return; el.textContent = txt; el.style.opacity = '1'; clearTimeout(Term._ft); Term._ft = setTimeout(() => { el.style.opacity = '.5'; el.textContent = '📋 Copiar texto, o Shift+arrastrar + botón derecho'; }, 1600); },
  // Vuelca todo el texto del terminal (incl. scrollback) como texto plano.
  dumpText(){
    try { const buf = Term.term.buffer.active; const out = [];
      for (let i = 0; i < buf.length; i++){ const ln = buf.getLine(i); out.push(ln ? ln.translateToString(true) : ''); }
      return out.join('\n').replace(/\s+$/, '');
    } catch(e){ return ''; }
  },
  openCopyText(){
    if (!Term.term){ alert('Abre o selecciona una sesión primero.'); return; }
    const ta = $('copyArea'); ta.value = Term.dumpText() || '(terminal vacío)';
    $('copyOv').classList.add('on');
    setTimeout(() => { ta.focus(); ta.select(); }, 30);
  },
  closeCopyText(){ $('copyOv').classList.remove('on'); if (Term.term) Term.term.focus(); },
  copyAllText(){
    const ta = $('copyArea'); ta.focus(); ta.select();
    let ok = false; try { ok = document.execCommand('copy'); } catch(e){}
    if (!ok && navigator.clipboard) { navigator.clipboard.writeText(ta.value).catch(()=>{}); ok = true; }
    Term.flash(ok ? 'Copiado ✓' : 'No se pudo copiar');
  },
  // ── Pegar (Windows + Android) ───────────────────────────────────────────────
  // Camino rápido: leer el portapapeles del navegador (Windows Chrome/Edge, Android
  // Chrome con HTTPS). Si está bloqueado (sin permiso, sin HTTPS, Firefox, WebView…),
  // abrimos un cuadro donde el usuario pega con el método nativo del dispositivo.
  openPaste(forceOverlay){
    if (!Term.current){ alert('Abre o selecciona una sesión primero.'); return; }
    if (!forceOverlay && navigator.clipboard && navigator.clipboard.readText){
      navigator.clipboard.readText()
        .then(t => { if (t){ Term.doPaste(t); Term.flash('Pegado ✓ (' + t.length + ')'); } else Term._showPaste(); })
        .catch(() => Term._showPaste());
      return;
    }
    Term._showPaste();
  },
  _showPaste(){ const ta = $('pasteArea'); ta.value = ''; $('pasteOv').classList.add('on'); setTimeout(() => ta.focus(), 30); },
  closePaste(){ $('pasteOv').classList.remove('on'); if (Term.term) Term.term.focus(); },
  pasteSend(){
    const v = $('pasteArea').value; Term.closePaste();
    if (v){ Term.doPaste(v); Term.flash('Pegado ✓ (' + v.length + ')'); }
  },
  doFit(){ if(!Term.fit) return; try{ Term.fit.fit(); if(Term.current) Term.send({type:'resize',sessionId:Term.current,cols:Term.term.cols,rows:Term.term.rows}); }catch(e){} },
  connect(){
    if (Term._retry){ clearTimeout(Term._retry); Term._retry = null; }
    const proto = location.protocol === 'https:' ? 'wss' : 'ws';
    Term.ws = new WebSocket(proto + '://' + location.host + '/ws/assistant');
    Term.ws.onopen = () => {
      Term.setStatus('Conectado', true);
      Term._lastRx = Date.now(); Term._startHB();
      Term.send({ type:'list' });
      // Re-enganche tras una reconexión (suspensión del equipo, salto de red, timeout
      // del proxy o reinicio del proceso assistant): el tmux con `claude` sigue vivo,
      // solo hay que volver a tender el puente a la sesión activa. Sin esto el terminal
      // quedaba congelado y obligaba a refrescar la página y reabrir la sesión a mano.
      if (Term.current != null) Term.send({ type:'attach', sessionId:Term.current, cols:Term.term.cols, rows:Term.term.rows });
    };
    Term.ws.onclose = () => { Term._stopHB(); Term.setStatus('Desconectado — reintentando…', false); Term._retry = setTimeout(Term.connect, 1500); };
    Term.ws.onerror = () => Term.setStatus('Error de conexión', false);
    Term.ws.onmessage = ev => { Term._lastRx = Date.now(); let m; try{ m=JSON.parse(ev.data); }catch(e){ return; } if(m.type==='pong') return; Term.handle(m); };
  },
  // Watchdog de conexión viva: la API WebSocket del navegador no manda pings propios
  // ni avisa de los del servidor, así que un socket medio-abierto se queda en OPEN
  // para siempre y onclose nunca dispara. Sondeamos cada 15s y, si pasan 40s sin
  // recibir nada, forzamos el cierre para que la reconexión de onclose actúe.
  _startHB(){ Term._stopHB(); Term._hb = setInterval(Term._tick, 15000); },
  _stopHB(){ if (Term._hb){ clearInterval(Term._hb); Term._hb = null; } },
  _tick(){
    if (!Term.ws || Term.ws.readyState !== 1) return;
    if (Date.now() - Term._lastRx > 40000){ try { Term.ws.close(); } catch(e){} return; }
    Term.send({ type:'ping' });
  },
  // Al recuperar red o volver a la pestaña: si el socket no está vivo, reconecta ya;
  // si dice estar OPEN, sondea para descartar que sea un zombi.
  wake(){
    if (!Term.inited) return;
    const rs = Term.ws ? Term.ws.readyState : 3;
    if (rs === 1) Term.send({ type:'ping' });
    else if (rs !== 0) Term.connect();
  },
  send(o){ if(Term.ws && Term.ws.readyState===1) Term.ws.send(JSON.stringify(o)); },
  handle(m){
    if(m.type==='sessions'){ Term.sessions=m.sessions||[]; Term.renderSessions(); }
    else if(m.type==='created'||m.type==='attached'){ Term.current=m.sessionId; $('empty').style.display='none'; Term.term.clear(); Term.term.focus(); Term.doFit(); if(m.title)$('termTitle').textContent=m.title; Term.send({type:'list'}); }
    else if(m.type==='output'){ if(m.sessionId===Term.current) Term.term.write(m.data); }
    else if(m.type==='exit'){ if(m.sessionId===Term.current){ Term.setStatus('Sesión terminada', false); Term.current=null; $('termTitle').textContent=''; } Term.send({type:'list'}); }
    else if(m.type==='detached'){ if(m.sessionId===Term.current) Term.setStatus('Enganchada en otra pestaña', false); }
    else if(m.type==='renamed'){ if(m.sessionId===Term.current && m.title)$('termTitle').textContent=m.title; Term.send({type:'list'}); }
    else if(m.type==='error'){ Term.setStatus(m.data||'Error', false); }
  },
  renderSessions(){
    const el = $('sessList');
    if(!Term.sessions.length){ el.innerHTML='<div style="padding:10px;color:#5b6b88;font-size:12.5px">Sin sesiones activas</div>'; return; }
    el.innerHTML = Term.sessions.map(s =>
      `<div class="it ${s.sessionId===Term.current?'active':''}" onclick="Term.attach(${s.sessionId})">
         <span class="sname" id="sname_${s.sessionId}" ondblclick="Term.startRename(${s.sessionId},event)" title="Doble clic para renombrar">${esc(s.title||('Sesión #'+s.sessionId))}</span>
         <span class="x" onclick="event.stopPropagation();Term.terminate(${s.sessionId})" title="Terminar">✕</span>
       </div>`).join('');
  },
  startRename(id, ev){
    if(ev) ev.stopPropagation();
    const s = Term.sessions.find(x => x.sessionId === id); if(!s) return;
    const span = $('sname_' + id); if(!span || span.querySelector('input')) return;
    const cur = s.title || ('Sesión #' + id);
    const inp = document.createElement('input');
    inp.type = 'text'; inp.value = cur; inp.className = 'rename-in'; inp.maxLength = 255;
    inp.onclick = e => e.stopPropagation();
    span.textContent = ''; span.appendChild(inp);
    inp.focus(); inp.select();
    let done = false;
    const commit = (save) => {
      if(done) return; done = true;
      const v = inp.value.trim();
      if(save && v && v !== cur) Term.send({ type:'rename', sessionId:id, title:v });
      else Term.renderSessions();
    };
    inp.onkeydown = e => {
      if(e.key === 'Enter'){ e.preventDefault(); commit(true); }
      else if(e.key === 'Escape'){ e.preventDefault(); commit(false); }
    };
    inp.onblur = () => commit(true);
  },
  newSession(){ const cols=Term.term?Term.term.cols:120, rows=Term.term?Term.term.rows:30; Term.send({ type:'create', cols, rows }); },
  attach(id){ if(id===Term.current) return; Term.current=id; Term.term.clear(); Term.send({ type:'attach', sessionId:id, cols:Term.term.cols, rows:Term.term.rows }); },
  terminate(id){ if(confirm('¿Terminar esta sesión de Claude?')) Term.send({ type:'terminate', sessionId:id }); }
};

/* ════════════ Barra táctil móvil ════════════ */
/* Desplaza el historial (scroll) y envía flechas/Enter al terminal para elegir
   opciones cuando Claude ofrece 1/2/3. Las teclas van por WebSocket directo al
   PTY (no por el DOM), así no abrimos el teclado del móvil al navegar. */
(function(){
  const bar = $('touchbar'); if (!bar) return;
  const sendSeq = seq => { if (Term.current) Term.send({ type:'input', sessionId:Term.current, data:seq }); };
  // Respeta el "application cursor keys mode" (DECCKM): ESC O x vs ESC [ x.
  const arrow = dir => { const app = Term.term && Term.term.modes && Term.term.modes.applicationCursorKeysMode; sendSeq((app ? '\x1bO' : '\x1b[') + dir); };
  const page  = dir => { if (Term.term) Term.term.scrollLines(dir * Math.max(1, Term.term.rows - 2)); };
  const acts = {
    pageup:   () => page(-1),
    pagedown: () => page(1),
    bottom:   () => { if (Term.term) Term.term.scrollToBottom(); },
    up:       () => arrow('A'),
    down:     () => arrow('B'),
    enter:    () => sendSeq('\r'),
    tab:      () => sendSeq('\t'),
    esc:      () => sendSeq('\x1b'),
    paste:    () => Term.openPaste(),
  };
  bar.addEventListener('click', e => {
    const b = e.target.closest('button[data-act]'); if (!b) return;
    const f = acts[b.dataset.act]; if (f){ e.preventDefault(); f(); }
  });
})();

/* arranque: pestaña Tareas */
Tasks.loadList();
</script>
