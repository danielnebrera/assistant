<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Acceso · Assistant</title>
  <style>
    *{box-sizing:border-box}
    html,body{margin:0;height:100%;background:#0b0f17;color:#d6e0f0;font-family:"Segoe UI",Arial,sans-serif}
    body{display:flex;align-items:center;justify-content:center;padding:20px}
    .card{width:100%;max-width:360px;background:#0e1626;border:1px solid #1a2640;border-radius:14px;padding:28px 26px 24px;box-shadow:0 18px 50px #0006}
    .brand{display:flex;align-items:center;gap:9px;font-size:18px;font-weight:700;color:#fff;margin-bottom:4px}
    .brand .b-emoji{font-size:20px}
    .sub{font-size:12.5px;color:#5b6b88;margin-bottom:22px;line-height:1.5}
    label{display:block;font-size:12px;color:#7da0d8;font-weight:600;text-transform:uppercase;letter-spacing:.04em;margin:14px 0 6px}
    input{width:100%;background:#0b1120;border:1px solid #243861;border-radius:8px;color:#e6eefc;padding:11px 12px;font-size:14px;font-family:inherit}
    input:focus{outline:none;border-color:#2563eb}
    .btn{width:100%;margin-top:20px;border:none;border-radius:8px;background:#2563eb;color:#fff;padding:11px 14px;font-size:14px;font-weight:600;cursor:pointer}
    .btn:hover{background:#1d4ed8}
    .err{margin-top:16px;background:#3a1620;border:1px solid #5a2330;color:#ffb4b4;border-radius:8px;padding:10px 12px;font-size:13px}
    .foot{margin-top:18px;font-size:11.5px;color:#48566f;line-height:1.5;text-align:center}
  </style>
</head>
<body>
  <form class="card" method="POST" action="/assistant/login">
    <div class="brand"><span class="b-emoji">🌱</span> Assistant</div>
    <div class="sub">Acceso directo al asistente. Funciona aunque la aplicación esté caída.</div>

    <% if (error) { %><div class="err"><%= error %></div><% } %>

    <label for="user_name">Usuario</label>
    <input id="user_name" name="user_name" type="text" autocomplete="username" autofocus required>

    <label for="password">Contraseña</label>
    <input id="password" name="password" type="password" autocomplete="current-password" required>

    <input type="hidden" name="next" value="<%= next %>">
    <button class="btn" type="submit">Entrar</button>

    <div class="foot">Se valida contra la base de datos. Requiere permiso de acceso al asistente.</div>
  </form>
</body>
</html>
