# Asistente — copia a .env y rellena. El .env NO va al repo.
PORT=5510
BIND_ADDR=127.0.0.1

# Secretos JWT: DEBEN coincidir con los de la app (token emitido por el módulo users).
ACCESS_TOKEN_SECRET=cambiame
REFRESH_TOKEN_SECRET=cambiame

# CLI claude y directorio de trabajo = el código del cliente que el asistente evoluciona.
CLAUDE_BIN=claude
CLAUDE_WORK_DIR=/home/factory3/app
CLAUDE_HOME=/home/ubuntu

# URL pública de la app (para redirigir al login si no hay sesión).
APP_PUBLIC_URL=https://dev.factory3.cypress-electronics.com

# Almacén de sesiones (fuera del código, escribible por el agente)
SESSIONS_FILE=/home/factory3/assistant-data/sessions.json
